APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Resend API (requires: composer require resend/resend-laravel)
# Get your API key at resend.com/api-keys
# Verify hostflows.com.au as a sending domain in the Resend dashboard first
MAIL_MAILER=resend
RESEND_KEY=re_
MAIL_FROM_ADDRESS="hello@hostflows.com.au"
MAIL_FROM_NAME="HostFlows"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

STRIPE_PUBLIC=pk_live_
STRIPE_SECRET=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs — create each as a recurring monthly price in your Stripe dashboard
STRIPE_PRICE_GROWTH=price_   # Growth  — A$29/mo
STRIPE_PRICE_PRO=price_      # Pro     — A$79/mo
STRIPE_PRICE_AGENCY=price_   # Agency  — A$199/mo
STRIPE_PRICE_HOST=           # Legacy alias for Growth (optional, leave blank if not needed)
